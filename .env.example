# Reference values for local CrispyBrain setup.
# This file is documentation for operators; the workflows do not auto-load it.

N8N_BASE_URL=http://localhost:5678
CRISPYBRAIN_ASSISTANT_WEBHOOK_URL=http://localhost:5678/webhook/assistant
OLLAMA_BASE_URL=http://host.docker.internal:11434

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change-me

# The n8n credential name expected by the exported workflows.
POSTGRES_CREDENTIAL_NAME=Postgres account

# Required Ollama models for the current workflow set.
OLLAMA_CHAT_MODEL=llama3
OLLAMA_EMBED_MODEL=nomic-embed-text
